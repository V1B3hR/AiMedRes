{
  "name": "aimedres-mobile",
  "version": "1.0.0",
  "description": "AiMedRes Mobile Clinical Companion App",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
